[Unit]
Description=Class Records FastAPI backend
After=network.target

[Service]
User=classrecords
Group=classrecords
WorkingDirectory=/opt/class_records/app/backend
EnvironmentFile=/etc/class-records.env
ExecStart=/opt/class_records/py311/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --proxy-headers --forwarded-allow-ips 127.0.0.1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
